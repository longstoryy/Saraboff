generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("attendant")
  createdAt DateTime @default(now())
  audits    Audit[]
  sales     Sale[]
}

model Product {
  id           String     @id @default(cuid())
  name         String
  emoji        String     @default("🍺")
  category     String     @default("Beer")
  sellingPrice Float
  costPrice    Float      @default(0)
  currentStock Int        @default(0)
  createdAt    DateTime   @default(now())
  saleItems    SaleItem[]
}

model Sale {
  id          String     @id @default(cuid())
  attendantId String
  totalAmount Float
  totalProfit Float      @default(0)
  createdAt   DateTime   @default(now())
  attendant   User       @relation(fields: [attendantId], references: [id])
  items       SaleItem[]
}

model SaleItem {
  id          String  @id @default(cuid())
  saleId      String
  productId   String
  productName String
  quantity    Int
  unitPrice   Float
  unitCost    Float
  lineTotal   Float
  lineProfit  Float
  product     Product @relation(fields: [productId], references: [id])
  sale        Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
}

model Audit {
  id            String       @id @default(cuid())
  attendantId   String
  discrepancies Int          @default(0)
  createdAt     DateTime     @default(now())
  attendant     User         @relation(fields: [attendantId], references: [id])
  entries       AuditEntry[]
}

model AuditEntry {
  id            String @id @default(cuid())
  auditId       String
  productName   String
  productEmoji  String
  systemCount   Int
  physicalCount Int
  variance      Int
  audit         Audit  @relation(fields: [auditId], references: [id], onDelete: Cascade)
}
